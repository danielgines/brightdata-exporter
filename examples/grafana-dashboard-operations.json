{
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "Bright Data — continuous time-series monitoring. Drawdown rate, cost evolution per zone, traffic evolution, exporter health, and silent-when-healthy alerts. 100% Prometheus-driven; the time picker selects the visible window of recorded samples. Pair with the 'Bright Data — Account & Zones' dashboard for FinOps investigation with picker-driven aggregates.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "includeVars": false, "keepTime": false, "tags": ["brightdata", "finops"], "targetBlank": true, "title": "FinOps dashboard", "tooltip": "Picker-driven account + zones investigation (Infinity-driven)", "type": "dashboards"},
    {"asDropdown": false, "icon": "external link", "includeVars": false, "keepTime": false, "tags": [], "targetBlank": true, "title": "brightdata-exporter on GitHub", "tooltip": "", "type": "link", "url": "https://github.com/danielgines/brightdata-exporter"}
  ],
  "liveNow": false,
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["brightdata", "operations"],
  "templating": {"list": [{"current": {"selected": false, "text": "Prometheus", "value": "prometheus"}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "name": "datasource", "options": [], "query": "prometheus", "queryValue": "", "refresh": 1, "regex": "", "skipUrlSync": false, "type": "datasource"}]},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Bright Data — Operations",
  "uid": "brightdata-operations",
  "version": 1,
  "weekStart": "",
  "panels": [
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 100, "panels": [], "title": "Account drawdown", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Account balance over time. Useful to spot an unexpected drop (charge) or to estimate runway from the slope.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 15, "gradientMode": "opacity", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "linear", "lineWidth": 2, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "currencyUSD"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 101,
      "options": {"legend": {"calcs": ["lastNotNull", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_account_balance_usd", "legendFormat": "Balance", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_account_pending_costs_usd", "legendFormat": "Pending costs", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_account_spent_this_month_usd", "legendFormat": "Spent this month", "refId": "C"}
      ],
      "title": "Account balance / pending / spent",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Drawdown rate: positive means balance is decreasing. Computed as -deriv(balance[15m]) projected per day. Useful to see if the burn rate suddenly accelerates.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 25, "gradientMode": "opacity", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "linear", "lineWidth": 2, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}, "unit": "currencyUSD"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 102,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "-deriv(brightdata_account_balance_usd[15m]) * 86400", "legendFormat": "$/day burn rate", "refId": "A"}
      ],
      "title": "Burn rate ($/day)",
      "type": "timeseries"
    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}, "id": 200, "panels": [], "title": "Cost evolution", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Top 10 zones by cost over time. Each line is the rolling-window cost reported by the collector at scrape time.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}]}, "unit": "currencyUSD"}, "overrides": []},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 10},
      "id": 201,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "topk(10, brightdata_zone_cost_usd)", "legendFormat": "{{zone}}", "refId": "A"}
      ],
      "title": "Top 10 zones by cost",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Derived $/GB rate per zone. Useful to detect Bright Data silently raising prices or a zone changing pool tier.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 0, "gradientMode": "none", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "currencyUSD"}, "overrides": []},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 10},
      "id": 202,
      "options": {"legend": {"calcs": ["lastNotNull", "min", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_zone_rate_usd_per_gb", "legendFormat": "{{zone}}", "refId": "A"}
      ],
      "title": "Rate ($/GB) by zone",
      "type": "timeseries"
    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 19}, "id": 300, "panels": [], "title": "Traffic evolution", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Top 10 zones by total bandwidth consumed in the rolling window.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 20, "gradientMode": "opacity", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 20},
      "id": 301,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "topk(10, brightdata_zone_traffic_bytes{direction=\"total\"})", "legendFormat": "{{zone}}", "refId": "A"}
      ],
      "title": "Top 10 zones by traffic",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Total request volume (sum across all zones) by protocol. Helps spot traffic-pattern shifts.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 20, "gradientMode": "opacity", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "normal"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 20},
      "id": 302,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum by (proto) (brightdata_zone_requests{proto!=\"total\"})", "legendFormat": "{{proto}}", "refId": "A"}
      ],
      "title": "Requests by protocol (account-wide)",
      "type": "timeseries"
    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 29}, "id": 400, "panels": [], "title": "Health & alerts", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Exporter scrape success. 1 = healthy. Drops to 0 when the most recent scrape cycle failed.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "mappings": [{"options": {"0": {"color": "red", "index": 1, "text": "DOWN"}, "1": {"color": "green", "index": 0, "text": "UP"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "none"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 30},
      "id": 401,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_up", "instant": true, "refId": "A"}],
      "title": "Exporter",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Seconds since the last successful scrape cycle. Healthy = below 2× the scrape interval (default scrape interval is 300s, so green up to 600s). Red if the exporter hasn't refreshed in 15+ minutes — likely stuck or the upstream API is down. (Replaces the old 'API auth' panel — `/status.can_make_requests` measures proxy-network credentials, not API-token validity, and is misleading for API-only consumers.)",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 600}, {"color": "red", "value": 900}]}, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 30},
      "id": 402,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "time() - brightdata_exporter_last_scrape_timestamp_seconds", "instant": true, "refId": "A"}],
      "title": "Last scrape",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Median scrape cycle duration over the last 10 minutes. With 14 zones × 3 calls + 2 account calls at 1 req/s, expect ~45s. Sustained > 90s suggests rate-limit hits or slow upstream.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 90}, {"color": "red", "value": 180}]}, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 30},
      "id": 403,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_exporter_scrape_duration_seconds_sum / brightdata_exporter_scrape_duration_seconds_count", "instant": true, "refId": "A"}],
      "title": "Avg scrape duration",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Total scrape errors observed across all upstream endpoints. Persistent non-zero usually means a Bright Data plan change or token scope issue.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 10}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 30},
      "id": 404,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum(increase(brightdata_exporter_scrape_errors_total[1h]))", "instant": true, "refId": "A"}],
      "title": "Scrape errors (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Number of IPs Bright Data flags as currently unavailable across all zones. Series only emitted when > 0; absent = healthy.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 10}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 30},
      "id": 405,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum(brightdata_zone_ips_unavailable)", "instant": true, "refId": "A"}],
      "title": "IPs unavailable",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Number of static (datacenter/ISP) proxies awaiting replacement. Absent = healthy.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 30},
      "id": 406,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum(brightdata_zone_proxies_pending_replacement)", "instant": true, "refId": "A"}],
      "title": "Proxies pending replacement",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Bright Data network operational status by network type. 0 = down, 1 = up. The provider's own self-reported health.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 50, "gradientMode": "none", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "none", "max": 1.1, "min": -0.1}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
      "id": 407,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_network_status", "legendFormat": "{{network}}", "refId": "A"}
      ],
      "title": "Bright Data network status (per type)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Zone count by status over time. Drops in 'active' or jumps in 'deleted' usually correspond to deliberate config changes — useful as a deploy marker.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 25, "gradientMode": "opacity", "hideFrom": {"legend": false, "tooltip": false, "viz": false}, "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 5, "scaleDistribution": {"type": "linear"}, "showPoints": "never", "spanNulls": true, "stacking": {"group": "A", "mode": "none"}, "thresholdsStyle": {"mode": "off"}}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
      "id": 408,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "brightdata_zones_total", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "title": "Zone counts by status",
      "type": "timeseries"
    }
  ]
}
